# Copy to .env and adjust. All values are optional (sane defaults applied).

# Where the SQLite file lives (directory). Defaults to backend/data/
# DATA_DIR=/data

# Full DB URL — overrides DATA_DIR. Use this to switch to Postgres later.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/pongpoints

# CORS: comma-separated origins, or * for all. Set to your GitHub Pages URL in prod.
# CORS_ORIGINS=https://<username>.github.io

# Seed clubs on first boot (true/false)
# SEED_ON_STARTUP=true

# Admin PINs for the seeded clubs (keep real PINs out of git — set as app settings)
# STANMORE_PIN=changeme
# YORKGARDENS_PIN=changeme
